<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- VMS ID from env -->
    <property name="VMS_ID" value="${VMS_ID:-unknown}" />
    <property name="LOG_DIR" value="/tmp" />

    <!-- AUDIT LOG FILE -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>/tmp/${VMS_ID}_log.txt</file>

        <immediateFlush>true</immediateFlush>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>/tmp/archived/%d{yyyy-MM-dd}/${VMS_ID}_log-%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>

    </appender>

    <logger name="VmsAuditLogger" level="INFO" additivity="false">
        <appender-ref ref="AUDIT_FILE"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="AUDIT_FILE"/>
    </root>

</configuration>